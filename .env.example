# Same Supabase project as the Inventra web app (see Inventra/.env.local) —
# mobile talks to Supabase directly since Inventra's onboarding/auth logic
# lives in Next.js Server Actions, which aren't reachable from outside Next.
# The anon key is safe to embed in a client bundle; RLS enforces access.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Inventra's Next.js origin — used for the handful of endpoints that must
# stay server-side (e.g. app/api/mobile/billing/initiate-card, which needs
# the Paystack secret key). Matches Inventra's NEXT_PUBLIC_SITE_URL in
# production; point this at your LAN IP + port for local dev against
# `next dev` (e.g. http://192.168.1.20:3000).
EXPO_PUBLIC_API_URL=https://www.royalinventra.com.ng

# Displayed plan prices only (naira, whole numbers) — keep in sync with
# Inventra's NEXT_PUBLIC_PLAN_PRICE_MONTHLY/YEARLY. Actual charge amounts
# are always decided server-side, so a mismatch here is a copy bug, not a
# billing bug.
EXPO_PUBLIC_PLAN_PRICE_MONTHLY=5000
EXPO_PUBLIC_PLAN_PRICE_YEARLY=50000
